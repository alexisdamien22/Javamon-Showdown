<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controllers.FightController"
      alignment="CENTER"
      spacing="20"
      styleClass="root-container"
      stylesheets="@../styles/fightScene.css">

    <VBox spacing="10" styleClass="main-column">

        <Canvas fx:id="canvas"
                width="400"
                height="300"
                styleClass="battle-canvas"/>

        <Label fx:id="mainLabel"
               styleClass="main-label"/>

        <VBox spacing="5" styleClass="action-block">
            <Label fx:id="labelAttack"
                   text="Attack"
                   styleClass="section-title"/>

            <HBox spacing="10" styleClass="button-row">

                <Button fx:id="attackBtn1" onAction="#onAttack1Clicked" styleClass="attack-button" text="">
                    <graphic>
                        <VBox alignment="CENTER" styleClass="attack-content">
                            <Label styleClass="attack-name"/>
                            <Label styleClass="attack-type"/>
                            <Label styleClass="attack-pp"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="attackBtn2" onAction="#onAttack2Clicked" styleClass="attack-button" text="">
                    <graphic>
                        <VBox alignment="CENTER" styleClass="attack-content">
                            <Label styleClass="attack-name"/>
                            <Label styleClass="attack-type"/>
                            <Label styleClass="attack-pp"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="attackBtn3" onAction="#onAttack3Clicked" styleClass="attack-button" text="">
                    <graphic>
                        <VBox alignment="CENTER" styleClass="attack-content">
                            <Label styleClass="attack-name"/>
                            <Label styleClass="attack-type"/>
                            <Label styleClass="attack-pp"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="attackBtn4" onAction="#onAttack4Clicked" styleClass="attack-button" text="">
                    <graphic>
                        <VBox alignment="CENTER" styleClass="attack-content">
                            <Label styleClass="attack-name"/>
                            <Label styleClass="attack-type"/>
                            <Label styleClass="attack-pp"/>
                        </VBox>
                    </graphic>
                </Button>

            </HBox>
        </VBox>

        <VBox spacing="5" styleClass="action-block">
            <Label fx:id="labelSwitch"
                   text="Switch"
                   styleClass="section-title"/>

            <HBox spacing="10" styleClass="button-row">

                <Button fx:id="pokemon1" onAction="#onSwitch1" styleClass="switch-button" text=""/>
                <Button fx:id="pokemon2" onAction="#onSwitch2" styleClass="switch-button" text=""/>
                <Button fx:id="pokemon3" onAction="#onSwitch3" styleClass="switch-button" text=""/>

            </HBox>
        </VBox>

    </VBox>

    <ScrollPane fx:id="logScroll"
                fitToWidth="true"
                styleClass="log-scroll">
        <VBox fx:id="logContainer"
              spacing="6"
              styleClass="log-container"/>
    </ScrollPane>

</HBox>
